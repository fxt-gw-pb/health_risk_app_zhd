        { "at": 1.2, "action": "big_text", "text": "扫码，立即测一测" },
        { "at": 1.6, "action": "sub_text", "text": "糖尿病 · 高血压 · 心血管病 · 5 年风险自测" },
        { "at": 2.0, "action": "disclaimer", "text": "本工具仅供健康风险参考，不替代医生诊断；如有不适请及时就医。" }
      ] }
