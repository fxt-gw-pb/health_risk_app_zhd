        { "at": 2.8, "action": "report_enter", "dataRef": "report-data.json#layer1" },
        { "at": 3.2, "action": "report_summary", "text": "您的未来 5 年新发心血管病风险偏高。主要与脑卒中家族史、腰围有关。" },
