        { "at": 7.8, "action": "confirm_chip", "text": "已记录 · 每日睡眠时长：6.5小时", "emphasis": true, "hold": 2.0, "note": "★ 自然语言理解，给足停留" },
        { "at": 9.6, "action": "ai_bubble", "text": "请问您的身高（cm）和体重（kg）大约是多少？我来帮您算 BMI ～ 不清楚可以跳过" },
