        { "at": 1.8, "action": "typing_dots" },
        { "at": 2.4, "action": "ai_stream", "text": "建议以中等强度有氧为主，比如快走、骑车、游泳，每周累计 150 分钟以上，分 4–5 次完成；再加 2 次力量练习。久坐时每小时起身活动几分钟。运动循序渐进，如有胸闷气促请停下并就医。", "streamSeconds": 3.2 },
        { "at": 6.0, "action": "sources", "items": ["[1] 中国人群身体活动指南（2021）", "[2] 中国 2 型糖尿病防治指南（2020）"] }
      ] }
    },
    {
