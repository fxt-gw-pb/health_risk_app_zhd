        { "at": 5.2, "action": "fill_riskbar", "level": "高危", "bigNumber": "21.8%" },
        { "at": 5.8, "action": "grow_top5", "outcome": "cvd", "dataRef": "report-data.json#layer1.cards.cvd.top5" },
        { "at": 7.6, "action": "tap", "target": "为什么会这样？" },
        { "at": 8.0, "action": "why_card", "dataRef": "report-data.json#why_cvd_layer1" }
      ] }
