        { "at": 0.9, "action": "fast_fill_montage", "items": { "收缩压": "136", "舒张压": "84", "空腹血糖": "7.4", "糖化血红蛋白": "6.7", "总胆固醇": "5.4", "甘油三酯": "2.2" }, "durationSec": 2.4 },
        { "at": 3.6, "action": "report_update", "dataRef": "report-data.json#layer2" },
        { "at": 3.9, "action": "alert_banner", "tone": "amber", "text": "就医提醒：您的血糖指标已达到 2 型糖尿病诊断标准（中国 2 型糖尿病防治指南 2020），建议前往医院内分泌科确诊并规范管理。" },
        { "at": 4.8, "action": "card_to_suspected", "card": "糖尿病", "badge": "疑似已患" },
        { "at": 5.4, "action": "update_cards", "cards": { "心血管病": "14.5%", "高血压": "15.3%" } }
      ] }
    },
    {
      "id": "S6", "title": "收尾", "t0": 46.0, "t1": 49.5,
